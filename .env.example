# ═══════════════════════════════════════════════════════════════════════════
# Variables de entorno — copiar a .env.local (nunca subir secretos al repositorio)
# 2026-04-28: Plantilla compatible con desarrollo local y despliegue en Vercel.
# ═══════════════════════════════════════════════════════════════════════════

# --- MySQL / phpMyAdmin (host público si Vercel; localhost sólo desarrollo local) ---
# 2026-04-28: Se reemplazan valores sensibles por placeholders para evitar exposición de credenciales.
MYSQL_HOST=tu-host-mysql
MYSQL_PORT=3306
MYSQL_USER=tu_usuario_mysql
MYSQL_PASSWORD=tu_password_mysql
MYSQL_DATABASE=tu_base_de_datos
# Límite de conexiones del pool serverless (bajo volumen habitual 3–10)
MYSQL_POOL_LIMIT=5

# --- Sesión JWT (HS256): mínimo 32 caracteres aleatorios ---
# 2026-04-28: Ejemplo de generación: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# Contraseña de portal compartida (sustituir por consulta a BD / LDAP / proveedor OAuth)
PORTAL_AUTH_PASSWORD=

# Opcional: exigir fila en `datos_facturacion` antes de login (true/false)
# REQUIRE_FACTURACION_ROW=false

# Opcional: duración de cookie de sesión en segundos (por defecto 43200 = 12 h)
# SESSION_MAX_AGE=43200

# Sólo desarrollo: permitir nombres desde el body del login (no usar en producción)
# SESSION_NAMES_FROM_LOGIN=false
